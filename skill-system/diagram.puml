@startuml

class Player {
    - name: string
    - int mana
    - stats: vector<Stats>
    - abilities: vector<Ability>

    + addPlayerStats()
    + updateCoolDowns()
    + applyAbilityOnPlayer()
    + consumeMana()
}

class Ability {
    - name: string
    - manaCost: int
    - abilityPoints: int
    - coolDownValue: int
    - currentCoolDown: int

    + canActivate()
    + applyCoolDown()
}

Player "1" *-- "*" Ability

@enduml